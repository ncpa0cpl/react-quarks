{
  "languages": {
    "JavaScript": {
      "language_servers": ["typescript-language-server"],
      "code_actions_on_format": {
        "source.removeUnusedImports": true,
      },
      "formatter": {
        "external": {
          "command": "dprint",
          "arguments": ["fmt", "--stdin", "{buffer_path}"],
        },
      },
    },
    "TypeScript": {
